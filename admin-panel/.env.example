# API base URL для admin-panel
VITE_API_URL=http://localhost:3000

# WebSocket URL (если пусто, формируется из API URL)
VITE_WS_URL=ws://localhost:3000

# Базовый URL для файлов/изображений (fallback: VITE_API_URL)
VITE_UPLOADS_URL=http://localhost:3000

# Username бота без @, нужен для ссылок в модуле подписочных кампаний
VITE_TELEGRAM_BOT_USERNAME=

# Локальный dev-порт Vite (опционально)
VITE_DEV_PORT=5174
