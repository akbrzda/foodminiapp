{
  "name": "miniapp-panda-backend",
  "version": "1.0.0",
  "description": "Backend API для системы онлайн-заказа еды",
  "main": "src/index.js",
  "type": "module",
  "scripts": {
    "dev": "nodemon src/index.js",
    "start": "node src/index.js",
    "worker": "node src/workers/index.js",
    "init-db": "node src/scripts/init-db.js",
    "migrate": "node src/scripts/migrate.js",
    "test": "node --import ./tests/bootstrap.js --test",
    "lint": "eslint src tests --ext .js",
    "typecheck": "node --check src/index.js && node --check src/modules/auth/auth.routes.js && node --check src/scripts/migrate.js"
  },
  "keywords": [
    "food",
    "delivery",
    "telegram",
    "miniapp"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "axios": "^1.13.6",
    "bcrypt": "^6.0.0",
    "bullmq": "^5.66.4",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.1",
    "helmet": "^8.1.0",
    "ioredis": "^5.9.1",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.1.1",
    "mysql2": "^3.16.0",
    "sharp": "^0.34.5",
    "winston": "^3.19.0",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "eslint": "^8.57.1",
    "nodemon": "^3.1.11",
    "supertest": "^7.2.2"
  }
