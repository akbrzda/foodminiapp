# ====================================
# Backend: Runtime
# ====================================
NODE_ENV=development
PORT=3000
WORKERS_MODE=inline
TRUST_PROXY=false
AUTH_COOKIE_SECURE=true
AUTH_COOKIE_SAMESITE=none

# ====================================
# Backend: Security
# ====================================
JWT_SECRET=your_jwt_secret_change_me_in_production
ENCRYPTION_KEY=your_encryption_key_change_me_in_production_64_chars_minimum
ADMIN_REFRESH_SESSION_HOURS=12

# ====================================
# Backend: Database
# ====================================
DB_HOST=localhost
DB_PORT=3306
DB_NAME=db_name
DB_USER=db_user
DB_PASSWORD=db_password

# ====================================
# Backend: Redis
# ====================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redis_password

# ====================================
# Backend: Telegram + MiniApp
# ====================================
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
MAX_BOT_TOKEN=your_max_bot_token
TELEGRAM_MINIAPP_URL=https://your-miniapp-url

# ====================================
# Backend -> Bot Service (internal)
# ====================================
BOT_SERVICE_URL=http://localhost:3002
BOT_SERVICE_TOKEN=change_me

# ====================================
# Backend: Internal API routing
# ====================================
# INTERNAL_API_URL используется для вызовов между сервисами
INTERNAL_API_URL=

# ====================================
# Backend: API / CORS / CDN
# ====================================
CORS_ORIGINS=http://localhost:5174,http://localhost:5173
CDN_BASE_URL=https://cdn.akbrzda.ru
CDN_IMAGES_PATH=/var/www/cdn.akbrzda.ru/images

# ====================================
# Backend: Upsell cache
# ====================================
UPSELL_CACHE_TTL_SECONDS=300

# ====================================
# Backend: Broadcast workers
# ====================================
BROADCAST_WORKER_ENABLED=true
BROADCAST_WORKER_BATCH_SIZE=50
BROADCAST_WORKER_INTERVAL_MS=2000
BROADCAST_RATE_LIMIT=28
BROADCAST_RETRY_MAX=3
BROADCAST_RETRY_DELAYS=5,15,60
BROADCAST_CONVERSION_WINDOW_DAYS=7
BROADCAST_WS_STATS_EVERY=100
BROADCAST_WS_STATS_FAIL_EVERY=25
BROADCAST_DB_TIMEOUT_BACKOFF_BASE_MS=5000
BROADCAST_DB_TIMEOUT_BACKOFF_MAX_MS=120000

# ====================================
# Backend: BullMQ workers
# ====================================
BULLMQ_WORKER_LOCK_DURATION_MS=120000
BULLMQ_WORKER_MAX_STALLED_COUNT=3
BULLMQ_WORKER_DRAIN_DELAY_S=5
