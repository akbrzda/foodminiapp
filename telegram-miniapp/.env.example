# Backend API URL (можно указывать с /api или без)
VITE_API_URL=http://localhost:3000/api

# WebSocket URL (если пусто, формируется из VITE_API_URL)
VITE_WS_URL=ws://localhost:3000

# Базовый URL для файлов/изображений (fallback: VITE_API_URL)
VITE_UPLOADS_URL=http://localhost:3000

# Локальный dev-порт Vite (опционально)
VITE_DEV_PORT=5173
